---
layout: null
---
[
{% assign docs = site.pages | concat: site.posts | where_exp: "item", "item.url != '/search/'" | where_exp: "item", "item.url != '/404.html'" | where_exp: "item", "item.url != '/feed.xml'" %}
{% for doc in docs %}
  {
    "title": {{ doc.title | default: doc.name | jsonify }},
    "url": {{ doc.url | relative_url | jsonify }},
    "content": {{ doc.content | strip_html | strip_newlines | jsonify }}
  }{% unless forloop.last %},{% endunless %}
{% endfor %}
]
